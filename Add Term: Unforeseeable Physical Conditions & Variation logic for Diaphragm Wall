import pandas as pd
from datetime import datetime

def check_diaphragm_wall_claim_eligibility(event_date, notice_date, is_in_geo_report, delay_days):
    """
    判断连续墙遇孤石等异常地质的索赔合规性 (FIDIC Clause 4.12 & 20.1)
    """
    # 雅思核心词汇注释：Calculate the duration to ensure compliance with the 28-day statutory period.
    days_lapsed = (notice_date - event_date).days
    
    print(f"--- 索赔初步评估启动 (Claim Assessment Initiated) ---")
    
    # 1. 检验时效性限制 (Time-bar check under Clause 20.1)
    if days_lapsed > 28:
        return "Claim Rejected: Notice submitted beyond the 28-day time-bar limit (Clause 20). 索赔失效。"
        
    # 2. 检验不可预见性 (Unforeseeability check under Clause 4.12)
    if is_in_geo_report:
        return "Claim Rejected: The boulder was foreseeable per the Geotechnical Report. 非不可预见物理条件。"
        
    # 3. 评估实质性影响 (Substantial impact evaluation)
    if delay_days > 0:
        return f"Claim Valid: Eligible for Extension of Time (EOT) and Cost under Clause 4.12. 建议发起索赔程序。"
    
    return "No Substantial Impact: Monitor the situation."

